  estimatedTreasury          Float?
  treasuryVerdict            String?
  loSnapshot                 String?
  bmSnapshot                 String?
  analystSnapshot            String?
  hocSnapshot                String?
  croSnapshot                String?
  cfoSnapshot                String?
  legalSnapshot              String?
  mdSnapshot                 String?
  governanceAudits           String?
  engineSnapshot             String?
  inventorySnapshot          String?
  assetsRegister             String?
  creditBureauReport         String?
  evidenceFiles              String?
  bmFieldVisit               String?
  bmRiskFlags                String?
  bmChecklist                String?
  bmTabAudits                String?
  bmReviewMeta               String?
  bmValidationData           String?
  hocStructureMeta           String?
