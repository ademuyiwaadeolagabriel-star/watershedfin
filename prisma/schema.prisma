  bmValidatedBy              String?
  bmReviewDate               DateTime?
  hocRecommendedAmount       Float?
  hocRecommendedTenor        Int?
  hocMoratorium              Int?
  hocRepaymentCycle          String?
  hocReviewStatus            String?
  hocReviewDate              DateTime?
  hocComment                 String?
  hocReviewComment           String?
  croComment                 String?
  cfoApprovedAmount          Float?
  cfoApprovedTenor           Int?
  scheduledDisbursementDate  DateTime?
