  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CallbackRequest {
  id            String    @id @default(cuid())
  userId        String
  preferredTime String
  reason        String
  status        String    @default("pending")
