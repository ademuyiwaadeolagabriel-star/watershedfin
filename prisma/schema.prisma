// ============================================================================
// WATERSHED FINANCE LIMITED — Banking Platform Prisma Schema
// ============================================================================
// Full schema covering 15 modules:
//   Identity, Onboarding, Branches, Loan Origination & Governance,
//   Credit Appraisal (CAM), Risk Engine, MCC, Compliance, Audit,
//   Treasury, Accounting, Savings, Investments, Communications, Settings
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// 1. IDENTITY & AUTH
// ============================================================================

model Admin {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  username        String   @unique
  email           String   @unique
  password        String
  phone           String?
  avatar          String?
  status          Int      @default(1) // 1=active, 0=suspended
  role            String   @default("admin") // super, md, cfo, hoc, cro, legal, bm, analyst, loan, frontdesk, treasury, admin
  roleType        String?  // alias used in workflow routing
  branchId        String?
  branch          Branch?  @relation("BranchStaff", fields: [branchId], references: [id])
  token           String?
  tokenExpired    DateTime?
  lastLogin       DateTime?
  lastLoginIp     String?

  // Permission flags (condensed from 60+ flags into role-implied + granular)
  // Core loan workflow
  loanOrigination     Boolean @default(false)
  loanVetting         Boolean @default(false)
  loanStructuring     Boolean @default(false)
  loanAnalyst         Boolean @default(false)
  loanRisk            Boolean @default(false)
  loanLegal           Boolean @default(false)
  loanCfoReview       Boolean @default(false)
  loanFinalization    Boolean @default(false)
  loanDisbursement    Boolean @default(false)
  loanPortfolio       Boolean @default(false)
  loanSupervisor      Boolean @default(false)
  loanMcc             Boolean @default(false)
  // Module access
  onboarding          Boolean @default(false)
  kycVerify           Boolean @default(false)
  accountingView      Boolean @default(false)
  accountingPost      Boolean @default(false)
  treasuryOnboard     Boolean @default(false)
  treasuryBook        Boolean @default(false)
  treasuryAssets      Boolean @default(false)
  branchManage        Boolean @default(false)
  auditAccess         Boolean @default(false)
  internalControl     Boolean @default(false)
  compliance          Boolean @default(false)
  reportsGlobal       Boolean @default(false)
  generalSettings     Boolean @default(false)
  // Legacy/CMS
  message             Boolean @default(true)
  support             Boolean @default(false)
  // v26 — Customer Service granular toggles
  csKycVerify         Boolean @default(false)
  csPaymentVerify     Boolean @default(false)
  // v26 — Legal dual role toggles
  legalCacSearch      Boolean @default(false)
  legalMcc            Boolean @default(false)

  // v26 — Password management
  mustChangePassword  Boolean @default(false)
  passwordResetToken  String?
  passwordResetExpires DateTime?
  passwordChangedAt   DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  loanOfficerLoans    LoanApplicants[] @relation("LoanOfficerLoans")
  bmVettedLoans       LoanApplicants[] @relation("BmVettedLoans")
  hocStructuredLoans  LoanApplicants[] @relation("HocStructuredLoans")
  managedUsers        User[]            @relation("UserLoanOfficer")
  analystLoans        CreditAppraisal[] @relation("AnalystAppraisals")
  managedBranches     Branch[]          @relation("BranchManager")
  bmVisits            BranchManagerVisit[]
  mccDecisions        MccDecision[]
  approvals           ApprovalLog[]
  auditLogs           AuditLog[]
  complianceConditions ComplianceCondition[]  @relation("ConditionsSetBy")
  verifiedConditions  ComplianceCondition[]  @relation("ConditionsVerifiedBy")
  riskAssessments     RiskAssessment[]       @relation("RiskOwner")
  exceptionReports    ExceptionReport[]      @relation("ExceptionReporter")
  assignedExceptions  ExceptionReport[]      @relation("ExceptionAssignee")
  journalEntries      JournalEntry[]
  tillTransactions    TillTransaction[]
  processedPayrollBatches PayrollBatch[] @relation("PayrollProcessedBy")
  approvedPayrollBatches  PayrollBatch[] @relation("PayrollApprovedBy")
  staffSalaries       StaffSalary[] @relation("StaffSalaryForAdmin")
  expenses            Expense[]
  sentEmails          SentEmail[]
  loginHistory        LoginHistory[]
  blogPosts           Blog[]        @relation("BlogAuthor")

  // v24 — Active sessions (force logout)
  activeSessions      ActiveSession[]

  // BM/LO Target tracking
  monthlyDisbursementTarget Float? // target loan disbursement volume (₦)
  monthlyLoanCountTarget   Int?    // target number of loans
  targetMonth             String? // YYYY-MM format for current target
  targetSetAt             DateTime?
  targetSetBy             String? // Admin ID who set the target

  // v41 — Multi-period targets (monthly, quarterly, annual)
  quarterlyDisbursementTarget Float?
  quarterlyLoanCountTarget   Int?
  targetQuarter              String?
  annualDisbursementTarget   Float?
  annualLoanCountTarget      Int?
  targetYear                 String?
  targetPeriodType           String?  @default("monthly")

  @@index([branchId])
  @@index([role])
}

model User {
  id                String   @id @default(cuid())
  firstName         String
  lastName          String
  email             String?  @unique
  phone             String?  @unique
  phoneCode         String?
  username          String?
  password          String?
  country           String?
  iso2              String?
  avatar            String?
  status            Int      @default(1)
  accountType       String   @default("customer") // customer, investor
  businessId        String?
  business          Business?
  branchId          String?
  branch            Branch?  @relation("BranchCustomers", fields: [branchId], references: [id])
  staffId           String?  // assigned Loan Officer (Admin.id)
  loanOfficer       Admin?   @relation("UserLoanOfficer", fields: [staffId], references: [id])
  assignedBranchId  String?
  assignedBmId      String?  // Branch Manager assigned to this client
  assignedBy        String?
  assignedAt        DateTime?
  assignmentStatus  String   @default("unassigned") // unassigned, pending_lo_assignment, assigned
  profileStatus     String   @default("incomplete") // incomplete, complete, pending_review
  onboardingChannel String?  // self_onboard, loan_officer, front_desk, bm
  createdBy         String?
  role              String?  // optional role for hybrid users
  roleType          String?
  accountNumber     String?  @unique // NUBAN
  merchantId        String?  @unique // for referrals
  referral          String?
  referredDate      DateTime?
  refWaivers        Int      @default(0)

  // KYC / Verification
  bvn               String?
  nin               String?
  bvnVerified       Boolean  @default(false)
  bvnVerifiedAt     DateTime?
  bvnMatchScore     Int?
  bvnPhotoPath      String?
  ninVerified       Boolean  @default(false)
  kycStatus         String?  // DRAFT, PENDING, PROCESSING, APPROVED, DECLINED, RESUBMIT
  gender            String?
  maritalStatus     String?
  religion          String?
  dob               DateTime?
  nationality       String?  @default("Nigerian")
  address           String?
  nearestLandmark   String?
  houseOwnership    String?
  yearsAtResidence  Int?
  dependents        Int?
  state             String?
  lga               String?
  town              String?

  // CAM handshake fields
  docPassportPath   String?
  docIdCardPath     String?
  guarantorFormPath String?
  hasExternalLoans  Boolean  @default(false)
  isGuarantorElsewhere Boolean @default(false)
  marketingChannel  String?
  previousLoanAmount Float?
  previousDefault   Boolean  @default(false)
  bankAccountVerified Boolean @default(false)
  bankName          String?
  loanPurpose       String?

  // Succession
  kinFirstName      String?
  kinLastName       String?
  kinMobile         String?
  kinEmail          String?
  kinAddress        String?
  successionPlanVerified Boolean @default(false)
  managementQualityScore Int?
  managementExperienceYears Float?

  // GPS
  gpsLatitude       Float?
  gpsLongitude      Float?
  gpsAccuracy       Float?
  gpsCapturedAt     DateTime?
  gpsCapturedBy     String?

  // Security & Auth
  emailVerify       Int      @default(0)
  phoneVerify       Int      @default(0)
  otpRequired       String   @default("on")
  verificationCode  String?
  emailTime         DateTime?
  phoneTime         DateTime?
  faStatus          String?
  faExpiring        DateTime?
  googlefaSecret    String?
  ipAddress         String?
  lastLogin         DateTime?
  loginAlert        Int      @default(1)
  transactionNotification Int @default(1)
  promotionalEmails Int      @default(1)
  language          String   @default("en")
  revealBalance     Int      @default(1)
  needsPhysicalVerification Boolean @default(false)
  physicallyVerifiedAt DateTime?
  verifiedByStaffId String?

  // v26 — Decoupled account number (only assigned after Legal CAC approval)
  accountNumberStatus String @default("pending") // pending, assigned, rejected
  accountNumberAssignedAt DateTime?
  accountNumberAssignedById String?
  onboardingStage    String @default("onboarding_submitted") // onboarding_submitted, cs_kyc_review, kyc_approved, payment_pending, payment_confirmed, legal_cac_search, legal_rejected, legal_approved, onboarding_complete

  // Settings
  pin               String?  // Hash::make
  social            String?
  socialAccountId   String?

  // Notification preferences (JSON string of toggles per channel/category)
  notificationPreferences String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  loans             LoanApplicants[]
  appraisals        CreditAppraisal[]
  savings           Savings[]
  investments       TreasuryInvestment[]
  transactions      Transactions[]
  tickets           Ticket[]
  beneficiaries     Beneficiary[]
  userBanks         UserBank[]
  contacts          Contact[]
  balance           Balance?
  investorProfile   InvestorProfile?
  loginHistory      LoginHistory[]
  kycSubmissions    KycSubmission[]
  onboardingConsents OnboardingConsent[]
  onboardingPayments OnboardingPayment[]
  legalNameSearches LegalNameSearch[]

  @@index([branchId])
  @@index([staffId])
  @@index([kycStatus])
  @@index([bvn])
}

model Business {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  reference         String?  @unique // NUBAN 10-digit
  description       String?
  sector            String?
  subSector         String?
  sectorId          String?
  country           String?
  sectorRef         Sector?  @relation(fields: [sectorId], references: [id])

  // Business type & legal
  businessType      String?  // individual, partnership, llc, company
  legalStructure    String?  // Individual, Enterprise, Partnership, Limited Liability, PLC
  rcBnNumber        String?
  rcNumber          String?
  ncrId             String?
  coOwners          String?
  cacVerifiedAt     DateTime?
  cacVerificationData String?

  // Location
  shopAddress       String?
  landmark          String?
  line1             String?
  line2             String?
  state             String?
  city              String?
  postalCode        String?
  zipCode           String?
  gpsLatitude       Float?
  gpsLongitude      Float?
  gpsAccuracy       Float?
  ownershipStatus   String?  // Rented, Owned, Family
  yearsAtLocation   Int?

  // Operations
  dateEstablished   DateTime?
  yearsInOperation  Float?
  vintageCalculated Int?
  operatingDaysWeek Int?

  // CAM financials
  businessWorth     Float?
  stockValue        Float?
  monthlySales      Float?
  dailyGoodSales    Float?
  dailyBadSales     Float?
  dailyAvgSales     Float?
  marketRiskCommentary String?
  competitionIntensity String? // Low, Medium, High, Intense
  financialStatement String?

  // KYC status
  kycStatus         String?  // DRAFT, PENDING, PROCESSING, APPROVED, DECLINED, RESUBMIT
  kycType           String?
  kycExpiry         DateTime?
  loanStatus        String?
  declineReason     String?
  physicallyVerifiedAt DateTime?
  verifierId        String?
  needsPhysicalVerification Boolean @default(false)
  guarantorVerifiedAt DateTime?

  // Documents
  selfie            String?
  docFront          String?
  docBack           String?
  docType           String?
  docNumber         String?
  proofOfAddress    String?
  sourceOfFunds     String?
  docShopPhoto      String?
  docCac            String?

  // KIN
  kinFirstName      String?
  kinLastName       String?
  kinMobile         String?
  kinMobileCode     String?
  kinEmail          String?
  kinAddress        String?

  // Guarantor
  guarantorName     String?
  guarantorPhone    String?
  guarantorEmail    String?
  guarantorAddress  String?
  guarantorRelationship String?
  docGuarantorId    String?
  docGuarantorForm  String?
  guarantorVerifiedAt2 DateTime?

  // Group guarantor
  gFirstName        String?
  gLastName         String?
  gEmail            String?
  gMobile           String?
  gAddress          String?
  gMobileCode       String?
  gDocType          String?
  gDocNumber        String?
  gDocFront         String?
  gDocBack          String?
  gProofOfAddress   String?

  // System
  revealBalance     Int      @default(1)
  pin               String?
  tag               String?
  otpRequired       String   @default("on")
  bDay              Int?
  bMonth            Int?
  bYear             Int?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Computed helpers (denormalized)
  // has_complete_cam_docs, has_gps_verification, health_score, risk_level — derived at runtime

  @@index([sectorId])
  @@index([kycStatus])
}

model Branch {
  id              String   @id @default(cuid())
  name            String
  code            String   @unique
  state           String?
  address         String?
  phoneContact    String?
  managerId       String?
  manager         Admin?   @relation("BranchManager", fields: [managerId], references: [id])
  status          String   @default("active") // active, inactive
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // v29 — Branch-level monthly targets (set by Super/MD, BM then distributes to LOs)
  monthlyDisbursementTarget Float?
  monthlyLoanCountTarget   Int?
  targetMonth             String?
  targetSetAt             DateTime?
  targetSetBy             String?

  // v41 — Multi-period targets (monthly, quarterly, annual)
  // Allows setting targets at different granularities simultaneously.
  // periodType: "monthly" | "quarterly" | "annual"
  // periodKey: "2024-01" (monthly) | "2024-Q1" (quarterly) | "2024" (annual)
  quarterlyDisbursementTarget Float?
  quarterlyLoanCountTarget   Int?
  targetQuarter              String?  // e.g. "2024-Q1"
  annualDisbursementTarget   Float?
  annualLoanCountTarget      Int?
  targetYear                 String?  // e.g. "2024"
  targetPeriodType           String?  @default("monthly") // current active period type

  staff           Admin[]           @relation("BranchStaff")
  customers       User[]            @relation("BranchCustomers")
  loans           LoanApplicants[]
  tills           Till[]
  bmVisits        BranchManagerVisit[] @relation("BranchVisits")

  @@index([status])
}

model BranchManagerVisit {
  id                  String   @id @default(cuid())
  loanApplicantId     String
  loan                LoanApplicants @relation(fields: [loanApplicantId], references: [id], onDelete: Cascade)
  branchManagerId     String
  branchManager       Admin    @relation(fields: [branchManagerId], references: [id])
  branchId            String?
  branch              Branch?  @relation("BranchVisits", fields: [branchId], references: [id])
  visitDate           DateTime
  gpsLatitude         Float?
  gpsLongitude        Float?
  gpsAccuracy         Float?
  distanceFromOriginal Float?
  businessOperating   Boolean  @default(false)
  stockVerified       Boolean  @default(false)
  stockMatchPercentage Float?
  customerPresent     Boolean  @default(false)
  verificationMethod  String   @default("in_person")
  timeSpentMinutes    Int      @default(0)
  notes               String?
  photos              String?  // JSON array
  createdAt           DateTime @default(now())

  @@index([loanApplicantId])
  @@index([branchManagerId])
}

// ============================================================================
// 2. LOAN PLANS / PRODUCTS & SECTORS
// ============================================================================

model Sector {
  id                String   @id @default(cuid())
  name              String   @unique
  riskScore         Float    @default(0.5) // 0-1, higher=safer (used by engine)
  riskScoreInt      Int?     // 1-5 scale (used by RiskEngineService)
  benchmarkedMargin Float?   // decimal percent e.g. 22.50
  createdAt         DateTime @default(now())
  businesses        Business[]
  loans             LoanApplicants[]

  @@index([name])
}

model LoanPlan {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  description       String?
  duration          Int      // months
  interest          Float    // % p.a.
  failedInterest    Float?
  installment       Int?
  min               Float?
  max               Float?
  type              String?  // loan, bnpl
  productType       String?
  suggestedAmount   Float?
  image             String?
  digitalLink       String?
  camTemplateConfig String?  // JSON
  minCreditScore    Float    @default(50)
  maxDebtServiceRatio Float  @default(33)
  status            Int      @default(1)
  breaks            Int      @default(0)
  amount            Float?
  catId             String?
  createdBy         String?
  editedBy          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  loans             LoanApplicants[]

  @@index([slug])
  @@index([status])
}

// ============================================================================
// 3. LOAN APPLICANTS (the loan entity — 20-state workflow)
// ============================================================================

model LoanApplicants {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  staffId           String?  // Loan Officer (Admin.id)
  loanOfficer       Admin?   @relation("LoanOfficerLoans", fields: [staffId], references: [id])
  branchId          String?
  branch            Branch?  @relation(fields: [branchId], references: [id])
  planId            String?
  plan              LoanPlan? @relation(fields: [planId], references: [id])
  acctId            String?

  // Request
  amount            Float
  payback           Float?
  duration          Int
  percent           Float?   // interest % p.a.
  reason            String?

  // Status & workflow
  status            String   @default("pending") // pending, processing, queried, running, paid, declined, pending_legal
  currentStep       String   @default("LO_ENTRY")
  // 20 steps: DRAFT, LO_ENTRY, LO_ASSESSMENT, QUERY_RESPONSE, LEGAL_CAC_CHECK,
  // BM_QC, HOC_STRUCTURING, ANALYST_STRUCTURING, HOC_APPROVAL, CRO_VERIFICATION,
  // CRO_RISK, CFO_REVIEW, LEGAL_REVIEW, LEGAL_FINAL_REVIEW, HOC_AGGREGATION,
  // MD_APPROVAL, HOC_FINALIZATION, CUSTOMER_ACCEPTANCE, HOC_SCHEDULING,
  // CFO_DISBURSEMENT, TREASURY_PAYOUT
  failedPercent     Float?
  complianceStatus  String   @default("pending") // pending, conditions_pending, conditions_met, cleared_for_disbursement
  hasComplianceConditions Boolean @default(false)
  applicationRef    String?  @unique // LN-2025-001
  refId             String?  @unique
  createdVia        String   @default("system")
  defaulter         Boolean  @default(false)

  // Vetted/structured/final amounts (Triple Lock)
  vettedAmount      Float?
  vettedDuration    Int?
  vettedInterestRate Float?
  structuredAmount  Float?
  structuredTenor   Int?
  finalAmount       Float?
  finalTenure       Int?
  finalInterestRate Float?
  finalCcdFeePercent Float?
  finalUpfrontFeePercent Float?
  finalAdminFee     Float?
  approvedAmount    Float?
  approvedTenor     Int?
  approvedDate      DateTime?
  appraisedAmount   Float?
  appraisedTenor    Int?

  // Repayment plan
  repaymentPlan     String   @default("REDUCING") // REDUCING, FLAT

  // Legal
  legalStatus       String?  // pending, cleared, queried
  legalOpinion      String?
  cacEvidencePath   String?
  cacStatusComment  String?
  isCacVerified     Boolean  @default(false)

  // Disbursement
  disbursementDate  DateTime?
  disbursedAt       DateTime?
  disbursedBy       String?
  startDate         DateTime?
  maturityDate      DateTime?
  signedOfferPath   String?
  fundSourceAccount String?

  // v26 — Post-disbursement monitoring owner (LO or BM who owns the customer)
  monitoringOwnerId String?

  // Customer acceptance
  digitalSignature  String?  // JSON
  acceptedAt        DateTime?

  // CRC report
  crcReportPath     String?
  crcReportUploadedAt DateTime?
  crcReportUploadedBy String?

  // Workflow timestamps
  submittedAt       DateTime?
  bmVerifiedAt      DateTime?
  bmValidatedBy     String?
  bmReviewDate      DateTime?
  hocStructuredAt   DateTime?
  analystReviewedAt DateTime?
  riskApprovedAt    DateTime?
  croCheckedAt      DateTime?
  legalClearedAt    DateTime?
  cfoClearedAt      DateTime?
  mdApprovedAt      DateTime?
  finalOfferGeneratedAt DateTime?
  offerLetterGeneratedAt DateTime?
  auditPassedAt     DateTime?
  hocFinalizedAt    DateTime?
  croFinalCheckAt   DateTime?
  cfoAuthorizedAt   DateTime?

  // Vetting (BM)
  bmRecommendedAmount Float?
  bmRecommendedTenor Int?
  bmComment         String?
  bmFieldVisit      String?  // JSON
  bmRiskFlags       String?  // JSON
  bmChecklist       String?  // JSON
  bmValidationData  String?  // JSON

  // Structuring (HOC)
  hocRecommendedAmount Float?
  hocRecommendedTenor Int?
  hocMoratorium     Int?
  hocRepaymentCycle String?
  hocComment        String?
  hocStructureMeta  String?  // JSON

  // CFO
  cfoApprovedAmount Float?
  cfoApprovedTenor Int?
  scheduledDisbursementDate DateTime?
  cfoComment        String?
  cfoReviewDate     DateTime?
  cfoVerifiedAt     DateTime?

  // CRO — max safe exposure (opinion, not override)
  riskApprovedAmount Float?

  // Final approval
  finalApprovedAmount Float?
  finalApprovedTenor Int?

  // Reference codes
  approvalReference String?
  offerCode         String?

  // Locking
  isLocked          Boolean  @default(false)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  bmValidator       Admin?   @relation("BmVettedLoans", fields: [bmValidatedBy], references: [id])
  hocStructurerId   String?
  hocStructurer     Admin?   @relation("HocStructuredLoans", fields: [hocStructurerId], references: [id])
  appraisal         CreditAppraisal?
  mccDecisions      MccDecision[]
  approvalLogs      ApprovalLog[]
  complianceConditions ComplianceCondition[]
  complianceDocuments ComplianceDocument[]
  complianceVerifications ComplianceVerification[]
  preDisbursementChecklist PreDisbursementChecklist?
  bmVisits          BranchManagerVisit[]
  loanDocuments     LoanDocument[]
  loanRepayments    LoanRepayment[]
  loanTransactions  LoanTransaction[]
  sectorRef         Sector?  @relation(fields: [sectorId], references: [id])
  sectorId          String?

  @@index([userId])
  @@index([staffId])
  @@index([branchId])
  @@index([status])
  @@index([currentStep])
  @@index([complianceStatus])
}

// ============================================================================
// 4. CREDIT APPRAISAL (the rich CAM memo with 8 snapshots)
// ============================================================================

model CreditAppraisal {
  id                String   @id @default(cuid())
  loanApplicantId   String   @unique
  loan              LoanApplicants @relation(fields: [loanApplicantId], references: [id], onDelete: Cascade)
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  staffId           String?
  branchId          String?
  bmId              String?
  hocId             String?
  assignedAnalystId String?
  analyst           Admin?   @relation("AnalystAppraisals", fields: [assignedAnalystId], references: [id])
  croId             String?
  sectorId          String?
  cfoId             String?

  // ===== Phase 1: Risk Snapshot =====
  applicantAge      Int?
  yearsAtAddress    Float?
  yearsInOperation  Float?
  managementExperience Float?
  successionPlanVerified Boolean?
  bankAccountVerified Boolean?
  previousDefault   Boolean?
  competitionIntensity String?
  marketRiskCommentary String?
  riskRating        String?  // JSON

  // ===== CAM financials (sales cross-check 4 sources) =====
  salesClientEstimate Float?
  salesSpotCheck    Float?
  salesBookRecord   Float?
  salesRecords      Float?
  salesBankStatement Float?
  consideredMonthlySales Float?
  selectedSalesSource String?

  // Purchases cross-check
  purchasesClientEstimate Float?
  purchasesBankDebit Float?
  purchasesInvoices Float?
  purchasesMarginDerived Float?
  consideredMonthlyPurchases Float?

  // Margin & inventory
  totalStockValue   Float?
  weightedMargin    Float?
  stockTurnoverFrequency Float?
  stockTurnoverDays Int?

  // Cashflow
  monthlyGrossProfit Float?
  monthlyBusinessExpenses Float?
  monthlyFamilyExpenses Float?
  irregularFamilyExpenses Float?
  otherLoanRepayments Float?
  monthlyNetSurplus Float?
  adjustedNetCashflow Float?
  salesOnCreditPercent Float?

  // Assets
  businessAssetValue Float?
  familyAssetValue  Float?

  // DSR (legacy field)
  dsrPercent        Float?

  // Scoring (4-axis, 100 pts)
  scoreFinancial    Float?  // out of 40
  scoreBusiness     Float?  // out of 20
  scoreIndustry     Float?  // out of 20
  scoreCollateral   Float?  // out of 20
  totalScore        Float?  // out of 100
  riskGradeLegacy   String? // A/B/C/D/F

  // Profile
  loanPurpose       String?
  loanCycle         Int?
  businessStartDate DateTime?
  bankName          String?
  accountNumber     String?

  // ===== Risk Engine (formalized) =====
  verifiedMonthlySales Float?
  verifiedMonthlyCogs Float?
  verifiedMonthlyNetProfit Float?
  dsrRatio          Float?  // decimal, limit 0.45
  dscrRatio         Float?  // target >1.25
  riskScore         Int?    // 0-100
  riskGrade         String? // A/B/C/D/F
  engineVerdict     String? // APPROVE, REVIEW, REJECT
  salesVariancePercent Float?
  hasHighVariance   Boolean?
  engineDump        String? // JSON

  // ===== Forensic / Treasury cross-check =====
  creditBureauHistory String? // JSON
  lastPurchaseDate  DateTime?
  evaluationDate    DateTime?
  cashSalesPerDay   Float?
  estimatedTreasury Float?
  treasuryVerdict   String?

  // ===== 8 SNAPSHOT COLUMNS (the waterfall cascade) =====
  loSnapshot        String?  // JSON — Loan Officer frozen
  bmSnapshot        String?  // JSON — Branch Manager vetted
  analystSnapshot   String?  // JSON — Credit Analyst structured
  hocSnapshot       String?  // JSON — Head of Credit golden record
  croSnapshot       String?  // JSON — CRO risk certificate
  cfoSnapshot       String?  // JSON — CFO liquidity
  legalSnapshot     String?  // JSON — Legal perfection
  mdSnapshot        String?  // JSON — MD sanction
  governanceAudits  String?  // JSON — threaded audit log
  engineSnapshot    String?  // JSON — full engine output
  inventorySnapshot String?  // JSON
  assetsRegister    String?  // JSON
  creditBureauReport String? // JSON
  evidenceFiles     String?  // JSON
  bmFieldVisit      String?  // JSON
  bmRiskFlags       String?  // JSON
  bmChecklist       String?  // JSON
  bmTabAudits       String?  // JSON
  bmReviewMeta      String?  // JSON
  bmValidationData  String?  // JSON
  hocStructureMeta  String?  // JSON
  balanceSheet      String?  // JSON
  marginAnalysis    String?  // JSON
  gpsData           String?  // JSON
  commentTrail      String?  // JSON

  // ===== Decision values (Triple Lock layers) =====
  bmRecommendedAmount Float?
  bmRecommendedTenor Int?
  bmComment         String?
  bmValidatedAt     DateTime?
  bmValidatedBy     String?
  bmReviewDate      DateTime?
  hocRecommendedAmount Float?
  hocRecommendedTenor Int?
  hocMoratorium     Int?
  hocRepaymentCycle String?
  hocReviewStatus   String?
  hocReviewDate     DateTime?
  hocComment        String?
  hocReviewComment  String?
  croComment        String?
  cfoApprovedAmount Float?
  cfoApprovedTenor  Int?
  scheduledDisbursementDate DateTime?
  fundSourceAccount String?
  cfoComment        String?
  cfoReviewDate     DateTime?
  cfoVerifiedAt     DateTime?
  finalApprovedAmount Float?
  finalApprovedTenor Int?
  finalInterestRate Float?
  cfoVerifiedAt2    DateTime?
  legalVerifiedAt   DateTime?
  mdVerifiedAt      DateTime?

  // ===== Governance / locking =====
  isSnapshotLocked  Boolean  @default(false)
  snapshotCreatedAt DateTime?
  status            String   @default("draft") // draft, submitted, approved, declined
  rejectionReason   String?
  submittedAt       DateTime?
  approvedAt        DateTime?

  // ===== GPS =====
  appraisalGpsLat   Float?
  appraisalGpsLong  Float?

  // ===== HOC structuring overrides =====
  unforeseenBufferRate Float? @default(0.20)

  // ===== EXCEL PARITY ADDITIONS (G6, G9, G10, G11) =====
  collateralRegister        String?  // JSON — full collateral detail (chassis, year, ownership, address, land measurement, title)
  guarantorRegister         String?  // JSON — full guarantor details (up to 2 guarantors with BVN, NIN, business, address, etc.)
  guarantorBizVerification  String?  // JSON — guarantor business verification data per guarantor
  bankBalancesRegister      String?  // JSON — array of {bankName, accountName, accountNumber, balance} up to 6 banks

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([loanApplicantId])
  @@index([userId])
  @@index([assignedAnalystId])
  @@index([riskGrade])
  @@index([engineVerdict])
}

// ============================================================================
// 5. MCC (Management Credit Committee) — 8-level decision ledger
// ============================================================================

model MccDecision {
  id                String   @id @default(cuid())
  loanApplicantId   String
  loan              LoanApplicants @relation(fields: [loanApplicantId], references: [id], onDelete: Cascade)
  approverId        String
  approver          Admin    @relation(fields: [approverId], references: [id])
  approverName      String
  approverRole      String   // LO, BM, CA, HOC, CRO, LEGAL, GCFO, MD
  approvalLevel     Int      // 1-8
  recommendedAmount Float?
  duration          Int?     // months
  ccdPercentage     Float?   // Capital Contribution Deposit %
  upfrontFeePercentage Float?
  interestRatePercentage Float?
  comment           String?
  decisionType      String   @default("approved") // approved, rejected, deferred, conditional
  decisionDate      DateTime @default(now())
  metadata          String?  // JSON

  // v42-P9: Committee signature fields (Excel COMMITTEE'S DECISION sheet)
  signatureData     String?  // typed name or base64 image
  signatureType     String?  @default("typed") // typed, uploaded
  signedAt          DateTime?
  ipAddress         String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([loanApplicantId, approverId, approverRole])
  @@index([loanApplicantId, approvalLevel])
  @@index([approverId])
  @@index([approverRole])
}

model ApprovalLog {
  id                String   @id @default(cuid())
  loanApplicantId   String
  loan              LoanApplicants @relation(fields: [loanApplicantId], references: [id], onDelete: Cascade)
  userId            String?
  adminId           String?
  admin             Admin?   @relation(fields: [adminId], references: [id])
  action            String   // APPROVED, REJECTED, QUERIED, DISBURSED, FORWARDED, RETURNED
  roleAtTimeOfAction String?
  comments          String?
  metadata          String?  // JSON
  createdAt         DateTime @default(now())

  @@index([loanApplicantId])
  @@index([adminId])
}

// ============================================================================
// 6. COMPLIANCE (Conditions, Documents, Verifications, Pre-Disbursement)
// ============================================================================

model ComplianceCondition {
  id                String   @id @default(cuid())
  loanApplicantId   String
  loan              LoanApplicants @relation(fields: [loanApplicantId], references: [id], onDelete: Cascade)
  mccDecisionId     String?
  setBy             String
  setByAdmin        Admin?   @relation("ConditionsSetBy", fields: [setBy], references: [id])
  setByRole         String?  // MD, CFO, CRO, LEGAL, HOC

  conditionType     String   // document_upload, field_update, guarantor_update, collateral_verification,
                              // account_validation, bvn_verification, address_verification,
                              // employment_verification, business_verification, insurance_required, other
  title             String
  description       String?
  instructions      String?
  requiredDocumentType String?
  fieldName         String?
  fieldExpectedValue String?

  priority          String   @default("medium") // low, medium, high, critical
  deadline          DateTime?

  status            String   @default("pending") // pending, customer_notified, document_uploaded, under_review, verified, rejected, waived, expired
  verifiedBy        String?
  verifiedAdmin     Admin?   @relation("ConditionsVerifiedBy", fields: [verifiedBy], references: [id])
  verifiedAt        DateTime?
  verificationNotes String?
  rejectedBy        String?
  rejectedAt        DateTime?
  rejectionReason   String?
  waivedBy          String?
  waivedAt          DateTime?
  waiverReason      String?

  metadata          String?  // JSON
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  documents         ComplianceDocument[]
  verifications     ComplianceVerification[]

  @@index([loanApplicantId, status])
  @@index([conditionType, status])
  @@index([deadline])
}

model ComplianceDocument {
  id                String   @id @default(cuid())
  complianceConditionId String?
  condition         ComplianceCondition? @relation(fields: [complianceConditionId], references: [id], onDelete: Cascade)
  loanApplicantId   String
  loan              LoanApplicants @relation(fields: [loanApplicantId], references: [id], onDelete: Cascade)
  documentType      String
  documentName      String
  filePath          String
  fileType          String?
  fileSize          Int?
  uploadedBy        String?
  uploaderType      String   @default("customer")
  status            String   @default("pending") // pending, approved, rejected, expired
  reviewedBy        String?
  reviewedAt        DateTime?
  reviewNotes       String?
  documentDate      DateTime?
  expiryDate        DateTime?
  createdAt         DateTime @default(now())

  @@index([loanApplicantId])
  @@index([complianceConditionId])
}

model ComplianceVerification {
  id                String   @id @default(cuid())
  complianceConditionId String
  condition         ComplianceCondition @relation(fields: [complianceConditionId], references: [id], onDelete: Cascade)
  loanApplicantId   String
  loan              LoanApplicants @relation(fields: [loanApplicantId], references: [id], onDelete: Cascade)
  action            String   // created, notified_customer, document_received, review_started, requested_info, info_provided, verified, rejected, re_uploaded, waived, escalated, deadline_extended
  notes             String?
  metadata          String?  // JSON
  performedBy       String?
  performerRole     String?
  previousStatus    String?
  newStatus         String?
  createdAt         DateTime @default(now())

  @@index([complianceConditionId])
  @@index([loanApplicantId])
}

model PreDisbursementChecklist {
  id                String   @id @default(cuid())
  loanApplicantId   String   @unique
  loan              LoanApplicants @relation(fields: [loanApplicantId], references: [id], onDelete: Cascade)

  allConditionsVerified Boolean @default(false)
  documentsComplete  Boolean  @default(false)
  customerKycValid   Boolean  @default(false)
  guarantorKycValid  Boolean  @default(false)
  collateralDocumented Boolean @default(false)
  offerLetterSigned  Boolean  @default(false)
  bankAccountVerified Boolean @default(false)
  disbursementAccountConfirmed Boolean @default(false)
  customItems        String?  // JSON

  status            String   @default("pending") // pending, in_progress, completed, disbursement_approved, disbursement_rejected
  approvedBy        String?
  approvedAt        DateTime?
  approvalNotes     String?
  rejectedBy        String?
  rejectedAt        DateTime?
  rejectionReason   String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ============================================================================
// 7. LOAN DOCUMENTS, REPAYMENTS, TRANSACTIONS
// ============================================================================

model LoanDocument {
  id                String   @id @default(cuid())
  loanApplicantId   String
