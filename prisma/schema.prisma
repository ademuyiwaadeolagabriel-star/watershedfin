  accountId         String
  account           ChartOfAccount @relation(fields: [accountId], references: [id])
  debit             Float    @default(0)
  credit            Float    @default(0)
  createdAt         DateTime @default(now())

  @@index([journalEntryId])
  @@index([accountId])
}

model BankTransaction {
  id                String   @id @default(cuid())
  chartOfAccountId  String
  account           ChartOfAccount @relation(fields: [chartOfAccountId], references: [id])
  date              DateTime
  description       String?
  reference         String?
  debit             Float    @default(0)
  credit            Float    @default(0)
  balance           Float?
  isReconciled      Boolean  @default(false)
  matchedJournalItemId String?
  reconciledAt      DateTime?
  reconciledBy      String?
  importBatch       String?
  createdAt         DateTime @default(now())

  @@index([chartOfAccountId])
  @@index([isReconciled])
}

model Vendor {
  id                String   @id @default(cuid())
  name              String
  email             String?
  phone             String?
  address           String?
  taxId             String?
  bankName          String?
  accountNumber     String?
  accountName       String?
  paymentTerms      Int      @default(30) // days
  isActive          Boolean  @default(true)
  payableAccountId  String?
  payableAccount    ChartOfAccount? @relation("VendorPayableAccount", fields: [payableAccountId], references: [id])
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  bills             VendorBill[]
  payments          VendorPayment[]

  @@index([name])
}

model VendorBill {
