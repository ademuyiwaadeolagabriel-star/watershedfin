model TreasuryProduct {
  id                String   @id @default(cuid())
  name              String
  description       String?
  minAmount         Float    @default(0)
  maxAmount         Float?
  interestRatePa    Float    // % per annum
  minTenorDays      Int      @default(30)
  maxTenorDays      Int      @default(365)
  whtRate           Float    @default(10) // %
  earlyLiquidationPenalty Float @default(20) // %
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  investments       TreasuryInvestment[]
}

model TreasuryInvestment {
  id                String   @id @default(cuid())
  subscriptionCode  String   @unique // INV-2025-888
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  productId         String
  product           TreasuryProduct @relation(fields: [productId], references: [id])

  principal         Float
  interestRate      Float
  tenorDays         Int
  startDate         DateTime
  maturityDate      DateTime

  accruedInterest   Float    @default(0)
  whtDeducted       Float    @default(0)

