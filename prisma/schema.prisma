model ExceptionReport {
  id                String   @id @default(cuid())
  exceptionCode     String?  @unique // EXC-YYYY-NNNNN
  title             String
  description       String?
  category          String?  // transaction, compliance, operational, security, fraud, credit
  type              String?
  severity          String   @default("medium") // low, medium, high, critical
  priority          String   @default("normal") // low, normal, high, urgent
