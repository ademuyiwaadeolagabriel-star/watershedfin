  reporterId        String?
  reporter          Admin?   @relation("ExceptionReporter", fields: [reporterId], references: [id])
  assignedToId      String?
  assignedTo        Admin?   @relation("ExceptionAssignee", fields: [assignedToId], references: [id])
  assignedAt        DateTime?

  resolutionType    String?  // confirmed_fraud, policy_violation, error, false_positive, acceptable_risk, other
  resolvedById      String?
  resolvedAt        DateTime?
  resolutionNotes   String?

  metadata          String?  // JSON
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

