  message    String
  isRead     Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([adminId, createdAt])
}

model Language {
  id     String  @id @default(cuid())
  name   String  @unique
  code   String  @unique
  status Boolean @default(true)
}
