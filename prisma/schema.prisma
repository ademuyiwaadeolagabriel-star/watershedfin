model Page {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  body      String
  status    String   @default("published")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Blog {
  id         String    @id @default(cuid())
  title      String
  slug       String    @unique
  body       String
  image      String?
  categoryId String?
  authorId   String?
  views      Int       @default(0)
  status     String    @default("published")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  author     Admin?    @relation("BlogAuthor", fields: [authorId], references: [id])
  category   Category? @relation("BlogCategory", fields: [categoryId], references: [id])

  @@index([slug])
  @@index([categoryId])
  @@index([authorId])
  @@index([status])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  type      String   @default("blog")
  createdAt DateTime @default(now())
  blogs     Blog[]   @relation("BlogCategory")

  @@index([slug])
}

model HelpCenterTopic {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
}

model HelpCenterArticle {
  id        String   @id @default(cuid())
  topicId   String?
  title     String
  slug      String   @unique
  body      String
  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id        String   @id @default(cuid())
  icon      String?
  title     String
  details   String?
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Social {
  id        String   @id @default(cuid())
  type      String
  value     String
  createdAt DateTime @default(now())
}

model Team {
  id        String   @id @default(cuid())
  name      String
  position  String?
  image     String?
  linkedin  String?
  twitter   String?
  createdAt DateTime @default(now())
}

model Review {
  id         String   @id @default(cuid())
  name       String
  occupation String?
  review     String
  image      String?
  status     Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model Brand {
  id        String   @id @default(cuid())
  name      String
  image     String?
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Country {
  id             String  @id @default(cuid())
  name           String  @unique
  code           String  @unique
  iso2           String?
  iso3           String?
  currency       String?
  currencySymbol String?
  dialCode       String?
  status         Boolean @default(true)
}

model Notification {
  id           String    @id @default(cuid())
  userId       String?
  adminId      String?
  type         String
  title        String
  message      String
  category     String    @default("loan")
  isRead       Boolean   @default(false)
  readAt       DateTime?
  actionLabel  String?
  actionView   String?
  actionParams String?
  metadata     String?
  createdAt    DateTime  @default(now())

  @@index([userId, isRead])
  @@index([adminId, isRead])
  @@index([createdAt])
}

model LoyaltyPoint {
  id        String   @id @default(cuid())
  userId    String
  points    Int
  reason    String
  loanId    String?
  metadata  String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model CreditTier {
  id               String   @id @default(cuid())
  userId           String   @unique
  tier             String   @default("BRONZE")
  totalPoints      Int      @default(0)
  streak           Int      @default(0)
  bestStreak       Int      @default(0)
  interestDiscount Float    @default(0)
  updatedAt        DateTime @updatedAt
}

model AchievementBadge {
  id         String   @id @default(cuid())
  userId     String
  badgeType  String
  badgeLabel String
  badgeIcon  String
  earnedAt   DateTime @default(now())

  @@unique([userId, badgeType])
  @@index([userId])
}

model FaqArticle {
  id        String   @id @default(cuid())
  question  String
  answer    String
