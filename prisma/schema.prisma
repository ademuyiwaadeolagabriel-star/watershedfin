// Admin-configurable KYC field definitions.
// Admin can add/remove/reorder fields without code changes.
model KycField {
  id              String   @id @default(cuid())
  key             String   @unique // e.g. "bvn", "nin", "next_of_kin_phone"
  label           String
  description     String?
  helpText        String?
  type            String   // text, number, email, phone, date, select, textarea, file, checkbox
  options         String?  // JSON array for select type: ["Option1", "Option2"]
  section         String   @default("personal") // personal, physical, business, financial
  required        Boolean  @default(true)
  editable        Boolean  @default(true) // customer can edit after submission
  needsVerification Boolean @default(false) // admin must verify this field
  placeholder     String?
  validationPattern String? // regex pattern for client-side validation
  validationMessage String? // error message when pattern fails
  sortOrder       Int      @default(0)
  enabled         Boolean  @default(true)
  adminOnly       Boolean  @default(false) // only admin can fill (internal note)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  submissions     KycSubmission[]

  @@index([section, sortOrder])
  @@index([enabled])
}

// Customer-submitted KYC values (one row per field per user)
model KycSubmission {
  id              String   @id @default(cuid())
  userId          String
  fieldId         String
  value           String   // stored as string; cast based on KycField.type
  fileName        String?  // for file-type fields: original filename
  filePath        String?  // for file-type fields: server-side path
  verified        Boolean  @default(false)
  verifiedById    String?
  verifiedAt      DateTime?
  verificationNote String?
  editedAt        DateTime?
  editedById      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  field           KycField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([userId, fieldId])
  @@index([userId])
  @@index([fieldId])
  @@index([verified])
}

// ============================================================================
// v26 — ONBOARDING GOVERNANCE MODELS
// ============================================================================

// Customer consent to pay CAC search fee (captured at onboarding)
model OnboardingConsent {
  id              String   @id @default(cuid())
  userId          String
  feeKey          String   // e.g. "fee_cac_search"
  feeAmount       Float    // amount captured at consent time
  acceptedAt      DateTime @default(now())
  ipAddress       String?
  userAgent       String?

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Onboarding fee payment (Paystack or manual bank transfer)
model OnboardingPayment {
  id              String   @id @default(cuid())
  userId          String
  amount          Float
  method          String   // paystack, transfer
  status          String   @default("pending") // pending, confirmed, rejected
  reference       String?  // Paystack reference or bank transfer ref
  proofOfPaymentPath String? // for manual transfer: uploaded proof file
  confirmedById   String?
  confirmedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// Legal CAC Name Search (onboarding stage — pre account number)
model LegalNameSearch {
  id              String   @id @default(cuid())
  userId          String
  assignedToLegalId String? // Admin ID of Legal staff
  status          String   @default("pending") // pending, in_review, approved, rejected, customer_responded
  searchResult    String?
  rejectionReason String?
  customerResponse String? // customer's response if rejected
  approvedById    String?
  approvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// Logs every rework cycle in the loan workflow (HOC return to analyst, etc.)
model WorkflowRework {
  id              String   @id @default(cuid())
  loanId          String
  fromStep        String
  toStep          String
  reworkedById    String
  reason          String
  comments        String?
  createdAt       DateTime @default(now())

  @@index([loanId])
  @@index([reworkedById])
}

// Compliance questions to customers (at compliance review step)
model ComplianceQuery {
  id              String   @id @default(cuid())
  loanId          String
  question        String
  customerResponse String?
  status          String   @default("pending") // pending, answered, resolved
  askedById       String?
  askedAt         DateTime @default(now())
  answeredAt      DateTime?

  @@index([loanId])
  @@index([status])
}
