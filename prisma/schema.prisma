model MccDecision {
  id                     String         @id @default(cuid())
  loanApplicantId        String
  approverId             String
  approverName           String
  approverRole           String
  approvalLevel          Int
  recommendedAmount      Float?
  duration               Int?
  ccdPercentage          Float?
  upfrontFeePercentage   Float?
  interestRatePercentage Float?
  comment                String?
  decisionType           String         @default("approved")
  decisionDate           DateTime       @default(now())
  metadata               String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  approver               Admin          @relation(fields: [approverId], references: [id])
  loan                   LoanApplicants @relation(fields: [loanApplicantId], references: [id], onDelete: Cascade)

  @@unique([loanApplicantId, approverId, approverRole])
  @@index([loanApplicantId, approvalLevel])
  @@index([approverId])
  @@index([approverRole])
}

model ApprovalLog {
  id                 String         @id @default(cuid())
  loanApplicantId    String
  userId             String?
  adminId            String?
  action             String
  roleAtTimeOfAction String?
  comments           String?
  metadata           String?
  createdAt          DateTime       @default(now())
  admin              Admin?         @relation(fields: [adminId], references: [id])
  loan               LoanApplicants @relation(fields: [loanApplicantId], references: [id], onDelete: Cascade)

  @@index([loanApplicantId])
  @@index([adminId])
}

model ComplianceCondition {
  id                   String                   @id @default(cuid())
  loanApplicantId      String
  mccDecisionId        String?
  setBy                String
  setByRole            String?
  conditionType        String
  title                String
  description          String?
  instructions         String?
  requiredDocumentType String?
  fieldName            String?
  fieldExpectedValue   String?
  priority             String                   @default("medium")
  deadline             DateTime?
  status               String                   @default("pending")
  verifiedBy           String?
  verifiedAt           DateTime?
  verificationNotes    String?
  rejectedBy           String?
  rejectedAt           DateTime?
  rejectionReason      String?
  waivedBy             String?
  waivedAt             DateTime?
  waiverReason         String?
  metadata             String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  loan                 LoanApplicants           @relation(fields: [loanApplicantId], references: [id], onDelete: Cascade)
  setByAdmin           Admin                    @relation("ConditionsSetBy", fields: [setBy], references: [id])
  verifiedAdmin        Admin?                   @relation("ConditionsVerifiedBy", fields: [verifiedBy], references: [id])
  documents            ComplianceDocument[]
  verifications        ComplianceVerification[]

  @@index([loanApplicantId, status])
  @@index([conditionType, status])
  @@index([deadline])
}

model ComplianceDocument {
  id                    String               @id @default(cuid())
  complianceConditionId String?
  loanApplicantId       String
  documentType          String
  documentName          String
  filePath              String
  fileType              String?
  fileSize              Int?
  uploadedBy            String?
  uploaderType          String               @default("customer")
  status                String               @default("pending")
  reviewedBy            String?
  reviewedAt            DateTime?
  reviewNotes           String?
  documentDate          DateTime?
  expiryDate            DateTime?
  createdAt             DateTime             @default(now())
  condition             ComplianceCondition? @relation(fields: [complianceConditionId], references: [id], onDelete: Cascade)
  loan                  LoanApplicants       @relation(fields: [loanApplicantId], references: [id], onDelete: Cascade)

