  vendorId          String
  vendor            Vendor   @relation(fields: [vendorId], references: [id])
  date              DateTime
  dueDate           DateTime
  subtotal          Float
  taxAmount         Float    @default(0)
  totalAmount       Float
  totalPaid         Float    @default(0)
  status            String   @default("pending") // pending, partial, paid, unpaid
