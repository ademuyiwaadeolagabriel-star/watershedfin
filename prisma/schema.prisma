}

// ============================================================================
// 11. ACCOUNTING MODULE
// ============================================================================

model ChartOfAccount {
  id                String   @id @default(cuid())
  code              String   @unique
  name              String
  type              String   // asset, liability, equity, revenue, expense
  subType           String?  // cash, bank, current_asset, fixed_asset, current_liability, etc.
  currency          String   @default("NGN")
  isSystem          Boolean  @default(false)
  isActive          Boolean  @default(true)
  balance           Float    @default(0)
  parentId          String?
  parent            ChartOfAccount? @relation("AccountHierarchy", fields: [parentId], references: [id])
  children          ChartOfAccount[] @relation("AccountHierarchy")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  journalItems      JournalItem[]
  bankTransactions  BankTransaction[]
  expenses          Expense[]
  invoices          Invoice[]       @relation("InvoiceExpenseAccount")
  invoicesIncome    Invoice[]       @relation("InvoiceRevenueAccount")
  vendorBills       VendorBill[]
  vendorPayables    Vendor[]        @relation("VendorPayableAccount")
  tellers           Teller[]        @relation("TellerCashAccount")
  tills             Till[]          @relation("TillGlAccount")
  payrollPayments   PayrollBatch[]  @relation("PayrollPaymentAccount")
  payrollSalaries   PayrollBatch[]  @relation("PayrollSalaryExpenseAccount")
  staffSalaries     StaffSalary[]   @relation("StaffSalaryExpenseAccount")

  @@index([type])
  @@index([code])
}

model JournalEntry {
  id                String   @id @default(cuid())
  reference         String   @unique
  date              DateTime
  description       String
  createdById       String?
  createdBy         Admin?   @relation(fields: [createdById], references: [id])
  posted            Boolean  @default(true)
  isReversed        Boolean  @default(false)
  reversalReason    String?
  sourceType        String?  // loan, treasury, savings, manual
  sourceId          String?
  metadata          String?  // JSON
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  items             JournalItem[]

  @@index([date])
  @@index([reference])
}

model JournalItem {
  id                String   @id @default(cuid())
  journalEntryId    String
